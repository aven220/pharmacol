# ─── Plantilla .env para el SERVIDOR (20.5.19.8) ───────────────────────────
# Copiar en el servidor: cp .env.server.example .env && nano .env
# NO subir .env a Git.

# ─── Host producción ────────────────────────────────────────────────────────
PHARMACOL_HOST=20.5.19.8
PHARMACOL_HTTP_PORT=8080
API_PORT=3005

# Portal web (nginx en :8080) — URL pública para scripts y móvil
PHARMACOL_API="http://20.5.19.8:8080/v1"
# Build Docker del portal: ruta relativa (nginx proxy /v1 → backend)
VITE_API_URL="/v1"

# ─── PostgreSQL ─────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=cambiar-password-postgres-seguro
DATABASE_URL="postgresql://pharmacol:cambiar-password-postgres-seguro@localhost:5433/pharmacol?schema=public"

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6380"

# ─── JWT (mínimo 32 caracteres) ───────────────────────────────────────────
JWT_ACCESS_SECRET="cambiar-access-secret-minimo-32-caracteres"
JWT_REFRESH_SECRET="cambiar-refresh-secret-minimo-32-caracteres"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── OpenAI (opcional) ──────────────────────────────────────────────────────
OPENAI_API_KEY=""

# ─── INVIMA / Socrata ───────────────────────────────────────────────────────
INVIMA_APP_TOKEN=""
SYNC_CRON_CUM="0 3 * * *"
SYNC_CRON_DM="0 4 * * *"

# ─── Object Storage (opcional) ──────────────────────────────────────────────
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="pharmacol-images"

# ─── Cifrado (32 caracteres) ────────────────────────────────────────────────
AES_ENCRYPTION_KEY=""

# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=production
CORS_ORIGINS="*"
