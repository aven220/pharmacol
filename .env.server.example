# ─── Plantilla .env para el SERVIDOR con HTTPS (:443) ───────────────────────
# cp .env.server.example .env && nano .env

# ─── URL pública HTTPS (nginx host → 127.0.0.1:8080) ───────────────────────
# Subdominio recomendado: pharmacol.tudominio.com
PHARMACOL_DOMAIN=pharmacol.tudominio.com
PHARMACOL_PUBLIC_URL="https://pharmacol.tudominio.com"
PHARMACOL_API="https://pharmacol.tudominio.com/v1"
PHARMACOL_HOST=pharmacol.tudominio.com

# Docker: solo localhost (nginx del servidor hace proxy desde :443)
PHARMACOL_HTTP_PORT=8080
API_PORT=3005
VITE_API_URL="/v1"

# ─── PostgreSQL ─────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=pharmacol_dev
DATABASE_URL="postgresql://pharmacol:pharmacol_dev@127.0.0.1:5433/pharmacol?schema=public"

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL="redis://127.0.0.1:6380"

# ─── JWT (mínimo 32 caracteres) ───────────────────────────────────────────
JWT_ACCESS_SECRET="cambiar-access-secret-minimo-32-caracteres"
JWT_REFRESH_SECRET="cambiar-refresh-secret-minimo-32-caracteres"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── OpenAI (opcional) ──────────────────────────────────────────────────────
OPENAI_API_KEY=""

# ─── INVIMA / Socrata ───────────────────────────────────────────────────────
INVIMA_APP_TOKEN=""
SYNC_CRON_CUM="0 3 * * *"
SYNC_CRON_DM="0 4 * * *"

# ─── Object Storage (opcional) ──────────────────────────────────────────────
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="pharmacol-images"

# ─── Cifrado (32 caracteres) ────────────────────────────────────────────────
AES_ENCRYPTION_KEY=""

# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=production
CORS_ORIGINS="*"
