# ─── PharmaCol — SERVIDOR PRODUCCIÓN (HTTPS :443) ───────────────────────────
# Copiar en el servidor:
#   cp .env.server.example .env && nano .env
#
# Arquitectura:
#   Internet → nginx :443 (HTTPS) → 127.0.0.1:8080 (Docker web) → backend:3005

# ─── Dominio público (EDITAR con tu subdominio real) ────────────────────────
PHARMACOL_DOMAIN=pharmacol.tudominio.com
PHARMACOL_PUBLIC_URL="https://pharmacol.tudominio.com"
PHARMACOL_HOST=pharmacol.tudominio.com

# API pública — móvil, navegador, clientes externos
PHARMACOL_API="https://pharmacol.tudominio.com/v1"

# API local — scripts en el servidor (sync INVIMA, token admin); no sale a internet
PHARMACOL_API_LOCAL="http://127.0.0.1:8080/v1"

# Docker: portal solo en localhost (nginx host hace proxy desde :443)
PHARMACOL_HTTP_PORT=8080
API_PORT=3005
VITE_API_URL="/v1"

# ─── PostgreSQL ─────────────────────────────────────────────────────────────
# Solo host (pg_dump, migrate manual). Docker backend usa postgres:5432 interno.
POSTGRES_PASSWORD=pharmacol_dev
DATABASE_URL="postgresql://pharmacol:pharmacol_dev@127.0.0.1:5433/pharmacol?schema=public"

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL="redis://127.0.0.1:6380"

# ─── JWT (mínimo 32 caracteres) ─────────────────────────────────────────────
JWT_ACCESS_SECRET="cambiar-access-secret-minimo-32-caracteres"
JWT_REFRESH_SECRET="cambiar-refresh-secret-minimo-32-caracteres"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

OPENAI_API_KEY=""
INVIMA_APP_TOKEN=""
SYNC_CRON_CUM="0 3 * * *"
SYNC_CRON_DM="0 4 * * *"

S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="pharmacol-images"
AES_ENCRYPTION_KEY="cambiar-aes-key-32-caracteres!!"

NODE_ENV=production
CORS_ORIGINS="*"
