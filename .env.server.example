# ─── PharmaCol — SERVIDOR con IP (sin dominio) ─────────────────────────────
# cp .env.server.example .env && nano .env
#
# Acceso público: https://20.5.19.8/  (certificado autofirmado)
# Docker interno: http://127.0.0.1:8080

# ─── IP pública del servidor ──────────────────────────────────────────────────
PHARMACOL_SERVER_IP=20.5.19.8
PHARMACOL_DOMAIN=20.5.19.8
PHARMACOL_HOST=20.5.19.8
PHARMACOL_PUBLIC_URL="https://20.5.19.8"
PHARMACOL_API="https://20.5.19.8/v1"
PHARMACOL_API_LOCAL="http://127.0.0.1:8080/v1"

PHARMACOL_HTTP_PORT=8080
API_PORT=3005
VITE_API_URL="/v1"

# ─── PostgreSQL ─────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=pharmacol_dev
DATABASE_URL="postgresql://pharmacol:pharmacol_dev@127.0.0.1:5433/pharmacol?schema=public"

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL="redis://127.0.0.1:6380"

# ─── JWT (mínimo 32 caracteres) ─────────────────────────────────────────────
JWT_ACCESS_SECRET="cambiar-access-secret-minimo-32-caracteres"
JWT_REFRESH_SECRET="cambiar-refresh-secret-minimo-32-caracteres"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

OPENAI_API_KEY=""
INVIMA_APP_TOKEN=""
SYNC_CRON_CUM="0 3 * * *"
SYNC_CRON_DM="0 4 * * *"

S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="pharmacol-images"
AES_ENCRYPTION_KEY="cambiar-aes-key-32-caracteres!!"

NODE_ENV=production
CORS_ORIGINS="*"

# Certificado autofirmado (scripts/generate-selfsigned-ip.sh)
PHARMACOL_SSL_DIR="/etc/nginx/ssl/pharmacol-ip"
