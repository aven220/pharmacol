# Portal web (React) + nginx — ruta /pharmacol/ junto a A-AS Delivery
FROM node:20-alpine AS admin-build
RUN corepack enable && corepack prepare pnpm@9.15.0 --activate
WORKDIR /app

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY apps/admin/package.json ./apps/admin/
RUN pnpm install --frozen-lockfile --filter @pharmacol/admin...

COPY apps/admin ./apps/admin
ARG VITE_API_URL=/pharmacol/v1
ARG VITE_BASE_PATH=/pharmacol/
ENV VITE_API_URL=$VITE_API_URL
ENV VITE_BASE_PATH=$VITE_BASE_PATH
RUN pnpm --filter @pharmacol/admin build

FROM nginx:1.27-alpine
ARG NGINX_CONF=web-subpath.conf
COPY infra/nginx/${NGINX_CONF} /etc/nginx/conf.d/default.conf
COPY --from=admin-build /app/apps/admin/dist /usr/share/nginx/html
EXPOSE 80
HEALTHCHECK --interval=30s --timeout=5s --retries=3 \
  CMD wget -qO- http://localhost/pharmacol/v1/health || exit 1
