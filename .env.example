# ─── Plantilla .env — DESARROLLO LOCAL (Mac) ────────────────────────────────
# En el servidor usa: cp .env.server.example .env

POSTGRES_PASSWORD=pharmacol_dev
DATABASE_URL="postgresql://pharmacol:pharmacol_dev@localhost:5433/pharmacol?schema=public"
REDIS_URL="redis://localhost:6380"

JWT_ACCESS_SECRET="cambiar-access-secret-minimo-32-caracteres"
JWT_REFRESH_SECRET="cambiar-refresh-secret-minimo-32-caracteres"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

OPENAI_API_KEY=""
INVIMA_APP_TOKEN=""
SYNC_CRON_CUM="0 3 * * *"
SYNC_CRON_DM="0 4 * * *"

S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="pharmacol-images"
AES_ENCRYPTION_KEY="cambiar-aes-key-32-caracteres!!"

NODE_ENV="development"
API_PORT=3005

# Dev local — admin Vite proxy
PHARMACOL_API="http://localhost:3005/v1"
VITE_API_URL="/v1"
